generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InstitutionStatus {
  draft
  active
  suspended
}

enum UserRole {
  ADMINISTRATIVE
  TEACHER
  STUDENT
}

enum PostTargetType {
  ALL
  ROLE
  COURSE
}

enum AcademicLevelType {
  BASIC
  MIDDLE
}

enum SectionNaming {
  LETTERS
  NUMBERS
}

enum CourseNameFormat {
  CHILE_TRADITIONAL
  COMPACT
  HUNDREDS
}

enum AcademicRegime {
  SEMESTER
  TRIMESTER
  QUARTER
}

enum CalendarEventType {
  GENERAL
  EXAM
  ASSIGNMENT
  HOLIDAY
  MEETING
  OTHER
}

enum GradeCategory {
  EXAM
  QUIZ
  ASSIGNMENT
  PROJECT
  ORAL
  OTHER
}

enum AnnotationType {
  POSITIVE
  NEGATIVE
  OBSERVATION
}

model Institution {
  id           String            @id @default(uuid()) @db.Uuid
  name         String            @unique
  contactEmail String?
  status       InstitutionStatus @default(draft)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appUsers     AppUser[]
  invitations  Invitation[]
  courses      Course[]
  posts        Post[]
  grades       Grade[]
  scheduleBlocks   ScheduleBlock[]
courseSchedules  CourseSchedule[]
scheduleSlots    ScheduleSlot[]

  courseConfig InstitutionCourseConfig?

  teacherCourses              TeacherCourse[]
  invitationCourseAssignments InvitationCourseAssignment[]

  academicPolicy      InstitutionAcademicPolicy?
  academicYears       AcademicYear[]
  academicPeriods     AcademicPeriod[]
  subjects            Subject[]
  courseSubjects      CourseSubject[]
  teachingAssignments TeachingAssignment[]
  calendarEvents      CalendarEvent[]

  studentAnnotations   StudentAnnotation[]
  studentAchievements  StudentAchievement[]
  improvementPlans     StudentImprovementPlan[]

  @@index([status])
}

model AppUser {
  id String @id @default(uuid()) @db.Uuid

  authUserId String @unique
  email      String @unique

  fullName      String?
  role          UserRole
  positionTitle String?
  isSuperAdmin  Boolean @default(false)

  institutionId String      @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  courseId String? @db.Uuid
  course   Course? @relation("StudentCourse", fields: [courseId], references: [id], onDelete: SetNull)

  profileCompletedAt DateTime?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  invitationsCreated    Invitation[]    @relation("InvitationCreatedBy")
  posts                 Post[]          @relation("PostsByAuthor")
  teacherCourses        TeacherCourse[]
  teachingAssignments   TeachingAssignment[]
  grades                Grade[]         @relation("StudentGrades")
  calendarEventsCreated CalendarEvent[] @relation("EventsCreatedBy")
  teacherSlots     ScheduleSlot[] @relation("TeacherSlots")

  // Perfil del alumno
  studentAnnotations       StudentAnnotation[]      @relation("StudentAnnotations")
  annotationsAuthored      StudentAnnotation[]      @relation("AnnotationAuthor")
  studentAchievements      StudentAchievement[]     @relation("StudentAchievements")
  achievementsAuthored     StudentAchievement[]     @relation("AchievementAuthor")
  improvementPlans         StudentImprovementPlan[] @relation("ImprovementPlans")
  improvementPlansAuthored StudentImprovementPlan[] @relation("ImprovementPlanAuthor")

  @@index([institutionId, role])
  @@index([institutionId, courseId])
  @@index([institutionId, isActive])
}

model Invitation {
  id        String @id @default(uuid()) @db.Uuid
  tokenHash String @unique

  email         String
  role          UserRole
  positionTitle String?

  courseId String? @db.Uuid
  course   Course? @relation("InvitationCourse", fields: [courseId], references: [id], onDelete: SetNull)

  courseAssignments InvitationCourseAssignment[]

  institutionId      String @db.Uuid
  createdByAppUserId String @db.Uuid

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  createdBy   AppUser     @relation("InvitationCreatedBy", fields: [createdByAppUserId], references: [id], onDelete: Cascade)

  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([institutionId])
  @@index([institutionId, email])
  @@index([expiresAt])
  @@index([courseId])
}

model InvitationCourseAssignment {
  id            String @id @default(uuid()) @db.Uuid
  invitationId  String @db.Uuid
  courseId      String @db.Uuid
  institutionId String @db.Uuid
  isChief       Boolean @default(false)

  // NUEVO
  subjectId     String? @db.Uuid
  subject       Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  invitation  Invitation  @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([invitationId, courseId])
  @@index([institutionId])
  @@index([courseId])
  @@index([courseId, isChief])
  @@index([subjectId])
}

model InstitutionCourseConfig {
  id            String      @id @default(uuid()) @db.Uuid
  institutionId String      @unique @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  activeLevels  String[]      @default([])
  sectionNaming SectionNaming @default(LETTERS)
  sectionCount  Int           @default(2)
  nameFormat    CourseNameFormat @default(CHILE_TRADITIONAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([institutionId])
}

model Course {
  id            String      @id @default(uuid()) @db.Uuid
  institutionId String      @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  levelCode   String
  levelType   AcademicLevelType
  levelNumber Int
  section     String
  name        String
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students                    AppUser[]                    @relation("StudentCourse")
  teacherCourses              TeacherCourse[]
  courseSubjects              CourseSubject[]
  teachingAssignments         TeachingAssignment[]
  postTargets                 PostTarget[]
  invitations                 Invitation[]                 @relation("InvitationCourse")
  invitationCourseAssignments InvitationCourseAssignment[]
  calendarEventTargets        CalendarEventTarget[]
  studentAnnotations          StudentAnnotation[]
  courseSchedules  CourseSchedule[]

  @@unique([institutionId, levelCode, section])
  @@unique([institutionId, name])
  @@index([institutionId])
  @@index([institutionId, isActive])
}

model TeacherCourse {
  id            String @id @default(uuid()) @db.Uuid
  teacherId     String @db.Uuid
  courseId      String @db.Uuid
  institutionId String @db.Uuid

  isChief Boolean @default(false)

  teacher     AppUser     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([teacherId, courseId])
  @@index([institutionId])
  @@index([teacherId])
  @@index([courseId])
  @@index([courseId, isChief])
}

model InstitutionAcademicPolicy {
  id            String      @id @default(uuid()) @db.Uuid
  institutionId String      @unique @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  academicRegime           AcademicRegime @default(SEMESTER)
  gradingScaleMin          Decimal        @db.Decimal(3, 1) @default(1.0)
  gradingScaleMax          Decimal        @db.Decimal(3, 1) @default(7.0)
  passingGrade             Decimal        @db.Decimal(3, 1) @default(4.0)
  gradeDecimals            Int            @default(1)
  useAttendanceForPromotion Boolean       @default(true)
  minimumAttendancePercent  Decimal?      @db.Decimal(5, 2)

  activeAcademicYearId String?       @db.Uuid
  activeAcademicYear   AcademicYear? @relation("ActiveAcademicYear", fields: [activeAcademicYearId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([institutionId])
}

model AcademicYear {
  id            String      @id @default(uuid()) @db.Uuid
  institutionId String      @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  year      Int
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean @default(false)

  periods             AcademicPeriod[]
  teachingAssignments TeachingAssignment[]
  activeForPolicy     InstitutionAcademicPolicy[] @relation("ActiveAcademicYear")
courseSchedules  CourseSchedule[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([institutionId, year])
  @@index([institutionId, isActive])
}

model AcademicPeriod {
  id            String      @id @default(uuid()) @db.Uuid
  institutionId String      @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  academicYearId String       @db.Uuid
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  name         String
  periodNumber Int
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean @default(false)

  grades Grade[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([academicYearId, periodNumber])
  @@index([institutionId])
  @@index([academicYearId, isActive])
}

model Subject {
  id            String      @id @default(uuid()) @db.Uuid
  institutionId String      @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  name     String
  code     String?
  isActive Boolean @default(true)

  courseSubjects      CourseSubject[]
  teachingAssignments TeachingAssignment[]
  // En model Subject agregar:
invitationCourseAssignments InvitationCourseAssignment[]
scheduleSlots    ScheduleSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([institutionId, name])
  @@unique([institutionId, code])
  @@index([institutionId, isActive])
}

model CourseSubject {
  id            String      @id @default(uuid()) @db.Uuid
  institutionId String      @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  courseId  String  @db.Uuid
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subjectId String  @db.Uuid
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([courseId, subjectId])
  @@index([institutionId])
  @@index([courseId])
  @@index([subjectId])
}

model TeachingAssignment {
  id            String      @id @default(uuid()) @db.Uuid
  institutionId String      @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  academicYearId String       @db.Uuid
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  teacherId String  @db.Uuid
  teacher   AppUser @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  courseId String @db.Uuid
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  subjectId String  @db.Uuid
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  grades Grade[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([academicYearId, teacherId, courseId, subjectId])
  @@index([institutionId])
  @@index([teacherId])
  @@index([courseId])
  @@index([subjectId])
}

model Grade {
  id            String      @id @default(uuid()) @db.Uuid
  institutionId String      @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  studentId String  @db.Uuid
  student   AppUser @relation("StudentGrades", fields: [studentId], references: [id], onDelete: Cascade)

  teachingAssignmentId String             @db.Uuid
  teachingAssignment   TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)

  academicPeriodId String         @db.Uuid
  academicPeriod   AcademicPeriod @relation(fields: [academicPeriodId], references: [id], onDelete: Cascade)

  value    Decimal       @db.Decimal(3, 1)
  title    String?
  weight   Decimal       @db.Decimal(4, 2) @default(1.0)
  category GradeCategory @default(OTHER)
  comment  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([institutionId])
  @@index([studentId])
  @@index([teachingAssignmentId])
  @@index([academicPeriodId])
}

model Post {
  id String @id @default(uuid()) @db.Uuid

  institutionId String @db.Uuid
  authorId      String @db.Uuid

  content String @db.VarChar(2000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  institution  Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  author       AppUser     @relation("PostsByAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  attachmentId String?     @db.Uuid
  attachment   Attachment? @relation(fields: [attachmentId], references: [id], onDelete: SetNull)
  targets      PostTarget[]

  @@index([institutionId, createdAt])
  @@index([authorId, createdAt])
}

model PostTarget {
  id     String         @id @default(uuid()) @db.Uuid
  postId String         @db.Uuid
  type   PostTargetType

  role     UserRole?
  courseId String?  @db.Uuid
  course   Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([type, role])
  @@index([type, courseId])
}

model Attachment {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  mimeType  String
  url       String
  size      Int?
  createdAt DateTime @default(now())

  posts Post[]
}

model CalendarEvent {
  id            String      @id @default(uuid()) @db.Uuid
  institutionId String      @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  createdByUserId String  @db.Uuid
  createdBy       AppUser @relation("EventsCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  title       String
  description String?
  type        CalendarEventType @default(GENERAL)
  date        DateTime
  endDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  targets CalendarEventTarget[]

  @@index([institutionId, date])
  @@index([createdByUserId])
}

model CalendarEventTarget {
  id      String        @id @default(uuid()) @db.Uuid
  eventId String        @db.Uuid
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  type     PostTargetType
  role     UserRole?
  courseId String?  @db.Uuid
  course   Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([type, courseId])
}

model StudentAnnotation {
  id            String      @id @default(uuid()) @db.Uuid
  institutionId String      @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  studentId String  @db.Uuid
  student   AppUser @relation("StudentAnnotations", fields: [studentId], references: [id], onDelete: Cascade)

  authorId String  @db.Uuid
  author   AppUser @relation("AnnotationAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  courseId String? @db.Uuid
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  type        AnnotationType
  title       String
  description String
  date        DateTime       @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([institutionId])
  @@index([studentId])
  @@index([authorId])
  @@index([studentId, type])
}

model StudentAchievement {
  id            String      @id @default(uuid()) @db.Uuid
  institutionId String      @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  studentId String  @db.Uuid
  student   AppUser @relation("StudentAchievements", fields: [studentId], references: [id], onDelete: Cascade)

  authorId String  @db.Uuid
  author   AppUser @relation("AchievementAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  title       String
  description String?
  date        DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([institutionId])
  @@index([studentId])
}

model StudentImprovementPlan {
  id            String      @id @default(uuid()) @db.Uuid
  institutionId String      @db.Uuid
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  studentId String  @db.Uuid
  student   AppUser @relation("ImprovementPlans", fields: [studentId], references: [id], onDelete: Cascade)

  authorId String  @db.Uuid
  author   AppUser @relation("ImprovementPlanAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  goal        String
  description String?
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([institutionId])
  @@index([studentId])
  @@index([studentId, isCompleted])
}

model ScheduleBlock {
  id            String   @id @default(uuid()) @db.Uuid
  institutionId String   @db.Uuid
  name          String   // "Bloque 1", "Recreo", etc.
  startTime     String   // "08:00"
  endTime       String   // "08:45"
  order         Int      // para ordenar los bloques
  isBreak       Boolean  @default(false) // si es recreo/almuerzo

  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  slots         ScheduleSlot[]

  @@unique([institutionId, order])
  @@index([institutionId])
}

model CourseSchedule {
  id            String   @id @default(uuid()) @db.Uuid
  institutionId String   @db.Uuid
  courseId      String   @db.Uuid
  academicYearId String  @db.Uuid
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution   Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  course        Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  slots         ScheduleSlot[]

  @@unique([institutionId, courseId, academicYearId])
  @@index([institutionId])
  @@index([courseId])
}

model ScheduleSlot {
  id               String   @id @default(uuid()) @db.Uuid
  institutionId    String   @db.Uuid
  courseScheduleId String   @db.Uuid
  blockId          String   @db.Uuid
  dayOfWeek        Int      // 1=Lunes, 2=Martes, 3=Miércoles, 4=Jueves, 5=Viernes, 6=Sábado
  subjectId        String?  @db.Uuid
  teacherId        String?  @db.Uuid
  room             String?  // aula opcional

  institution    Institution    @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  courseSchedule CourseSchedule @relation(fields: [courseScheduleId], references: [id], onDelete: Cascade)
  block          ScheduleBlock  @relation(fields: [blockId], references: [id], onDelete: Cascade)
  subject        Subject?       @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  teacher        AppUser?       @relation("TeacherSlots", fields: [teacherId], references: [id], onDelete: SetNull)

  @@unique([courseScheduleId, blockId, dayOfWeek])
  @@index([institutionId])
  @@index([courseScheduleId])
  @@index([teacherId])
}